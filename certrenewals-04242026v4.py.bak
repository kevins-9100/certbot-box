#!/usr/bin/env python3

import os
import sys
import json
import paramiko
import re
import time
import requests
import xml.etree.ElementTree as ET
from OpenSSL import crypto
from OpenSSL.crypto import FILETYPE_PEM
import secrets
import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
import subprocess

# Suppress insecure request warnings for Panorama
from requests.packages.urllib3.exceptions import InsecureRequestWarning
requests.packages.urllib3.disable_warnings(InsecureRequestWarning)

# --- CONFIGURATION & GLOBAL STATE ---
# Global State for Logging/Status
log_messages = []
script_status = "SUCCESS"

# Initial Configuration Load
API_KEY = os.getenv('PANORAMA_API_KEY')
if not API_KEY:
    print("ERROR: PANORAMA_API_KEY environment variable is not set. Aborting.")
    sys.exit(1)

# File Paths
PANORAMA_MAP_FILE = "/etc/letsencrypt/panorama_cert_map.json"
IIS_MAP_FILE = "/etc/letsencrypt/iis_cert_map.json"
COMMIT_LOCK_ERROR_TEXT_FILE = "/etc/letsencrypt/commit_lock_error_text.json"
EMAIL_SERVER_CONFIG_FILE = "/etc/letsencrypt/emailserver.json"
RECIPIENTS_CONFIG_FILE = "/etc/letsencrypt/recipients.json"

# Dynamic/Mutable Config
PASSPHRASE = secrets.token_urlsafe(16)
PANORAMA_IP = None
IIS_SSH_USER = "certbot"
IIS_SSH_KEY_PATH = "/home/certbot/.ssh/id_rsa"

# --- HELPER FUNCTIONS: LOGGING & EMAIL ---

def log_info(message):
    """Logs an informational message to the console and the global log."""
    print(f"INFO: {message}")
    log_messages.append(f"INFO: {message}")

def log_error(message):
    """Logs an error message, prints to stderr, and updates the script status."""
    global script_status
    print(f"ERROR: {message}", file=sys.stderr)
    log_messages.append(f"ERROR: {message}")
    script_status = "FAILURE"

def load_email_config():
    """Loads email server configuration from a JSON file."""
    try:
        with open(EMAIL_SERVER_CONFIG_FILE, 'r') as f:
            config = json.load(f)
            return config.get('SMTP_SERVER'), config.get('SMTP_PORT'), config.get('SENDER_EMAIL'), config.get('SMTP_PASSWORD')
    except (FileNotFoundError, json.JSONDecodeError, KeyError) as e:
        log_error(f"Failed to load email server config: {e}.")
        return None, None, None, None

def load_recipients():
    """Loads a list of email recipients from a JSON file."""
    try:
        with open(RECIPIENTS_CONFIG_FILE, 'r') as f:
            recipients = json.load(f)
            if not isinstance(recipients, list):
                raise ValueError("Recipients file must contain a list of email addresses.")
            return recipients
    except (FileNotFoundError, json.JSONDecodeError, ValueError) as e:
        log_error(f"Failed to load recipients config: {e}.")
        return []

def send_final_email(final_status, log_data):
    """Sends a single, consolidated email with the final status and full log. Retries on failure."""
    smtp_server, smtp_port, sender_email, smtp_password = load_email_config()
    recipients = load_recipients()

    if not all([smtp_server, smtp_port, sender_email, smtp_password]) or not recipients:
        log_error("Failed to send final email due to missing configuration.")
        return

    subject = f"Let's Encrypt Certificate Automation: {final_status}"
    message = MIMEMultipart("alternative")
    message["Subject"] = subject
    message["From"] = sender_email
    message["To"] = ", ".join(recipients)
    message.attach(MIMEText("\n".join(log_data), "plain"))

    MAX_RETRIES = 5
    RETRY_DELAY = 30  # seconds between retries

    for attempt in range(1, MAX_RETRIES + 1):
        try:
            with smtplib.SMTP(smtp_server, smtp_port) as server:
                server.ehlo()
                server.starttls()
                server.ehlo()
                server.login(sender_email, smtp_password)
                server.sendmail(sender_email, recipients, message.as_string())
            print(f"INFO: Final email sent successfully to {', '.join(recipients)} with subject: {subject}")
            return
        except smtplib.SMTPException as e:
            print(f"ERROR: Failed to send final email (attempt {attempt}/{MAX_RETRIES}). SMTP error: {e}", file=sys.stderr)
        except Exception as e:
            print(f"ERROR: Unexpected error sending final email (attempt {attempt}/{MAX_RETRIES}): {e}", file=sys.stderr)

        if attempt < MAX_RETRIES:
            print(f"INFO: Retrying email in {RETRY_DELAY} seconds...", file=sys.stderr)
            time.sleep(RETRY_DELAY)

    print(f"ERROR: Failed to send final email after {MAX_RETRIES} attempts. Giving up.", file=sys.stderr)

# --- HELPER FUNCTIONS: PANORAMA API ---

def api_call(url, method='GET', data=None, files=None, params=None):
    """Generic function to handle Panorama API calls (GET or POST)."""
    try:
        if method == 'POST':
            response = requests.post(url, data=data, files=files, params=params, verify=False, timeout=60)
        else: # GET
            response = requests.get(url, params=params, verify=False, timeout=60)

        response.raise_for_status()

        root = ET.fromstring(response.text)
        status = root.get('status')
        if status != 'success':
            log_error(f"API call failed. Status: {status}")
            log_error(f"Response: {response.text}")
            return None, response.text

        return root, response.text

    except requests.exceptions.RequestException as e:
        log_error(f"Request failed: {e}")
        return None, None

    except ET.ParseError as e:
        log_error(f"Failed to parse XML response. Raw response: {response.text}")
        return None, response.text

def wait_for_job(job_id):
    """Waits for an asynchronous Panorama job to complete."""
    log_info(f"Waiting for job {job_id} to complete...")
    TIMEOUT = 300
    interval = 10
    start_time = time.time()

    while (time.time() - start_time) < TIMEOUT:
        time.sleep(interval)
        STATUS_PARAMS = {
            'type': 'op',
            'cmd': f"<show><jobs><id>{job_id}</id></jobs></show>",
            'key': API_KEY
        }
        status_url = f"https://{PANORAMA_IP}/api/"
        root, _ = api_call(status_url, params=STATUS_PARAMS)
        if root is None:
            log_error(f"API call for job status failed. Retrying in {interval} seconds.")
            continue
        status_tag = root.find('.//status')
        if status_tag is None or status_tag.text in ('FAIL', 'UNKNOWN'):
            log_error(f"Panorama job {job_id} failed or has an unknown status.")
            return False
        if status_tag.text == 'FIN':
            return True

    log_error(f"Job {job_id} timed out.")
    return False

def handle_commit_lock(response_text):
    """Checks for a commit lock and logs a custom message if found."""
    if response_text and "commit locks" in response_text:
        log_error("Commit lock detected during commit/push attempt.")
        try:
            with open(COMMIT_LOCK_ERROR_TEXT_FILE, 'r') as f:
                lock_message_json = json.load(f)
                lock_message = lock_message_json.get("message", "Custom commit lock message not found in JSON file.")
                log_error(lock_message)
        except (FileNotFoundError, json.JSONDecodeError) as e:
            log_error(f"Failed to load custom commit lock error message from JSON file: {e}")
        return True
    return False

# --- CORE LOGIC: PFX/P12 CREATION ---

def create_pkcs12_pfx(fullchain_path, privkey_path, output_path, friendly_name, pfx_passphrase, is_legacy=False):
    """
    Creates a P12 or PFX file. Uses OpenSSL CLI for legacy PFX, or PyOpenSSL for modern P12/PFX.
    """
    if is_legacy:
        # --- LEGACY PATH (OpenSSL CLI) ---
        log_info(f"Creating LEGACY PFX for Exchange/Older IIS at {output_path}...")
        try:
            openssl_command = [
                'openssl', 'pkcs12', '-export',
                '-out', output_path,
                '-inkey', privkey_path,
                '-in', fullchain_path,
                '-name', friendly_name,
                '-legacy',
                '-passout', f'pass:{pfx_passphrase}'
            ]
            subprocess.run(openssl_command, check=True, capture_output=True, text=True)
            log_info("OpenSSL CLI PFX (legacy format) creation successful.")
            return True
        except subprocess.CalledProcessError as e:
            log_error(f"Failed to create LEGACY PFX using OpenSSL CLI. STDERR:\n{e.stderr}")
            return False
        except FileNotFoundError:
            log_error("OpenSSL command not found. Cannot create LEGACY PFX.")
            return False
    else:
        # --- MODERN PATH (PyOpenSSL) ---
        log_info(f"Creating MODERN P12/PFX at {output_path}...")
        try:
            with open(fullchain_path, 'r') as cert_file:
                cert_data = cert_file.read()

            cert_blocks = re.findall(r'-----BEGIN CERTIFICATE-----(.*?)-----END CERTIFICATE-----', cert_data, re.DOTALL)
            if not cert_blocks:
                raise ValueError("No certificates found in fullchain.pem.")

            certs = [crypto.load_certificate(crypto.FILETYPE_PEM, ('-----BEGIN CERTIFICATE-----' + block + '-----END CERTIFICATE-----').encode('utf-8')) for block in cert_blocks]
            main_cert = certs[0]
            ca_certs = certs[1:]

            with open(privkey_path, 'rb') as key_file:
                key = crypto.load_privatekey(crypto.FILETYPE_PEM, key_file.read())

            pfx_obj = crypto.PKCS12()
            pfx_obj.set_certificate(main_cert)
            pfx_obj.set_privatekey(key)
            if ca_certs:
                pfx_obj.set_ca_certificates(ca_certs)

            with open(output_path, 'wb') as pfx_f:
                pfx_f.write(pfx_obj.export(passphrase=pfx_passphrase.encode('utf-8')))

            log_info("PyOpenSSL P12/PFX (modern format) creation successful.")
            return True

        except Exception as e:
            log_error(f"Failed to create MODERN P12/PFX file using PyOpenSSL: {e}")
            return False

# --- CORE LOGIC: IIS DEPLOYMENT ---

def deploy_to_iis_ssh(cert_name, fullchain_path, privkey_path, iis_map_file, pfx_passphrase):
    """
    Deploys the certificate to IIS server(s) using SSH and an injected PowerShell script.
    Note: The critical PowerShell script logic remains untouched to preserve its functionality.
    """
    global IIS_SSH_USER, IIS_SSH_KEY_PATH
    log_info(f"\n--- Deploying '{cert_name}' to IIS servers via SSH ---")

    try:
        with open(iis_map_file, 'r') as f:
            iis_map = json.load(f)

        # Separate global defaults from deployments
        auth_defaults = iis_map.pop('_defaults_', {})
        if auth_defaults:
            IIS_SSH_USER = auth_defaults.get('username', IIS_SSH_USER)
            IIS_SSH_KEY_PATH = auth_defaults.get('ssh_key_path', IIS_SSH_KEY_PATH)
            log_info("Loaded authentication defaults from IIS map file.")

        deployments = iis_map.get(cert_name, [])
        if not deployments:
            log_info(f"No IIS deployments found for '{cert_name}'.")
            return True # Not an error if nothing is mapped
    except (FileNotFoundError, json.JSONDecodeError) as e:
        log_error(f"IIS mapping file problem: {e}. Skipping IIS deployment.")
        return False

    overall_success = True

    for deployment in deployments:
        server = deployment['server']
        website_name = deployment['website_name']
        ip_address = deployment.get('ip_address', '*')
        port_number = deployment.get('port_number', 443)
        host_header = deployment.get('host_header', cert_name)
        crypto_provider = deployment.get('crypto_provider', 'modern').lower()
        is_legacy_mode = (crypto_provider == 'legacy')
        ps_is_legacy_mode = '$true' if is_legacy_mode else '$false'

        mode_text = "LEGACY (CSP)" if is_legacy_mode else "MODERN (CNG)"
        log_info(f"\nTarget: {server} | Website: {website_name} | Mode: {mode_text}")

        temp_pfx_file = f"/tmp/{cert_name}_{server}.pfx"
        friendly_name = cert_name.split('.')[0] + '_letsencrypt_certautomation'

        # 1. CREATE PFX
        pfx_creation_success = create_pkcs12_pfx(
            fullchain_path, privkey_path, temp_pfx_file, friendly_name, pfx_passphrase, is_legacy=is_legacy_mode
        )

        if not pfx_creation_success:
            overall_success = False
            continue

        # 2. SSH/SFTP & Powershell Execution (CRITICAL BLOCK - UNTOUCHED)
        log_info(f"2. Deploying to IIS server '{server}' for website '{website_name}'")
        try:
            ssh_client = paramiko.SSHClient()
            ssh_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
            ssh_client.connect(hostname=server, username=IIS_SSH_USER, key_filename=IIS_SSH_KEY_PATH, look_for_keys=False)
            sftp_client = ssh_client.open_sftp()
            remote_temp_pfx = f'C:\\Users\\{IIS_SSH_USER}\\AppData\\Local\\Temp\\{os.path.basename(temp_pfx_file)}'
            sftp_client.put(temp_pfx_file, remote_temp_pfx)
            remote_ps_script_file = f'C:\\Users\\{IIS_SSH_USER}\\AppData\\Local\\Temp\\deploy_cert_{os.urandom(8).hex()}.ps1'

            # --- START CRITICAL POWERSHELL SCRIPT INJECTION ---
            ps_script_content = f"""
            Write-Output 'Starting PowerShell script...'
            $ErrorActionPreference = 'Stop'
            $pfxPass = ConvertTo-SecureString -String '{pfx_passphrase}' -AsPlainText -Force
            Write-Output 'Passphrase created.'
            $thumbprint = $null
            $certHash = $null

            $pfxPath = '{remote_temp_pfx}'
            $certStore = 'Cert:\\LocalMachine\\My'
            $certStoreName = 'My'
            $friendlyName = '{friendly_name}'

            Write-Output "Attempting to import PFX..."

            # --- START CERTIFICATE IMPORT BLOCK ---

            $importSuccess = $false

            # Attempt 1: Standard PFX import.
            try {{
                $cert = Import-PfxCertificate -FilePath $pfxPath -CertStoreLocation $certStore -Password $pfxPass
                Write-Output "SUCCESS: PFX imported using Import-PfxCertificate."
                $importSuccess = $true
                $thumbprint = $cert.Thumbprint
                $certHash = $cert.GetCertHash()
            }} catch {{
                Write-Warning "WARNING: Import-PfxCertificate failed or did not set the correct provider. Trying .NET fallback..."
            }}

            # Attempt 2: .NET Fallback (Run if the first attempt failed OR if legacy mode is explicitly requested)
            if (-not $importSuccess -or {ps_is_legacy_mode}) {{
                if ({ps_is_legacy_mode}) {{
                    Write-Output "Using .NET fallback to force LEGACY (CAPI/CSP) import for Exchange."
                    try {{
                        # CRITICAL FIX: This flag combination forces the key to be written to the CAPI store
                        $flags = [System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::MachineKeySet -bor `
                                 [System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::PersistKeySet -bor `
                                 [System.Security.Cryptography.X509Certificates.X509KeyStorageFlags]::Exportable

                        $cert = New-Object System.Security.Cryptography.X509Certificates.X509Certificate2($pfxPath, $pfxPass, $flags)

                        $store = New-Object System.Security.Cryptography.X509Certificates.X509Store($certStoreName, [System.Security.Cryptography.X509Certificates.StoreLocation]::LocalMachine)
                        $store.Open('ReadWrite')
                        $store.Add($cert)
                        $store.Close()

                        Write-Output "SUCCESS: PFX imported using .NET fallback (forced CAPI/CSP)."
                        $thumbprint = $cert.Thumbprint
                        $certHash = $cert.GetCertHash()
                        $importSuccess = $true

                    }} catch {{
                        Write-Output 'FATAL ERROR: .NET certificate import fallback failed. Details below:'
                        Write-Output $_.Exception.Message
                        exit 1
                    }}
                }}

                if (-not $importSuccess) {{
                    Write-Output 'ERROR: PowerShell certificate import failed and no legacy fallback requested. Details below:'
                    Write-Output $_.Exception.Message
                    exit 1
                }}
            }}

            # --- END CERTIFICATE IMPORT BLOCK ---

            Write-Output "Attempting to set friendly name using .NET..."
            try {{
                $cert = Get-Item "Cert:\\LocalMachine\\My\\$($thumbprint)"
                $cert.FriendlyName = $friendlyName
            }} catch {{
                Write-Output 'ERROR: Failed to set friendly name. This may be due to an old PowerShell version. Details:'
                Write-Output $_.Exception.Message
                exit 1
            }}

            Write-Output "Loading Microsoft.Web.Administration assembly..."
            try {{
                [Reflection.Assembly]::LoadWithPartialName("Microsoft.Web.Administration") | Out-Null
            }} catch {{
                Write-Output "ERROR: Failed to load Microsoft.Web.Administration assembly. Details:"
                Write-Output $_.Exception.Message
                exit 1
            }}
            $serverManager = New-Object Microsoft.Web.Administration.ServerManager
            Write-Output "ServerManager object created."
            Write-Output 'Getting IIS website '{website_name}'...'
            $site = $serverManager.Sites['{website_name}']
            if ($null -eq $site) {{
                Write-Error 'IIS website '{website_name}' not found.'
                exit 1
            }}
            Write-Output "SUCCESS: Website object retrieved."
            Write-Output "Checking for existing HTTPS bindings for host '{host_header}'..."
            $existingHttpsBindings = $site.Bindings | Where-Object {{ $_.protocol -eq 'https' -and $_.Host -eq '{host_header}' }}
            if ($null -ne $existingHttpsBindings) {{
                Write-Output 'Existing HTTPS bindings found. Removing them...'
                foreach ($binding in $existingHttpsBindings) {{
                    $site.Bindings.Remove($binding)
                }}
                Write-Output 'SUCCESS: Existing bindings removed.'
            }} else {{
                Write-Output 'No existing HTTPS bindings found for this host.'
            }}
            Write-Output "Creating new SSL binding..."
            try {{
                $newBinding = $site.Bindings.CreateElement("binding")
                $newBinding.Protocol = "https"
                $newBinding.BindingInformation = "{ip_address}:{port_number}:{host_header}"
                $newBinding.CertificateHash = $certHash
                $newBinding.CertificateStoreName = "My"
                $site.Bindings.Add($newBinding)
                $serverManager.CommitChanges()
                Write-Output "SUCCESS: New binding created and changes committed to IIS."
            }} catch {{
                Write-Output 'ERROR: PowerShell command failed. Details below:'
                Write-Output $_.Exception.Message
                exit 1
            }}
            Write-Output 'Final restart of website...'
            Restart-WebItem -PSPath 'IIS:\\Sites\\{website_name}'
            Write-Output 'SUCCESS: Website restarted.'
            Write-Output 'Cleaning up temporary files...'
            Remove-Item '{remote_temp_pfx}'
            Write-Output 'SUCCESS: Temporary PFX file removed.'
            exit 0
            """
            # --- END CRITICAL POWERSHELL SCRIPT INJECTION ---

            sftp_client.open(remote_ps_script_file, 'w').write(ps_script_content)
            sftp_client.close()
            log_info(f"DEBUG: Remote PowerShell script written to {remote_ps_script_file}")

            # Execute and capture output
            stdin, stdout, stderr = ssh_client.exec_command(f"powershell -ExecutionPolicy Bypass -NoProfile -File {remote_ps_script_file}")
            stdout_str = stdout.read().decode('utf-8')
            stderr_str = stderr.read().decode('utf-8')
            exit_code = stdout.channel.recv_exit_status()

            # Cleanup remote script file
            ssh_client.exec_command(f"Remove-Item {remote_ps_script_file}")
            ssh_client.close()

            log_info(f"PowerShell Exit Code on '{server}': {exit_code}")
            if stdout_str:
                log_info(f"PowerShell STDOUT:\n{stdout_str}")
            if stderr_str:
                log_error(f"PowerShell STDERR:\n{stderr_str}")

            if exit_code != 0:
                log_error(f"Remote PowerShell script failed.")
                overall_success = False
            else:
                log_info(f"Deployment to '{server}' for website '{website_name}' appears successful.")

        except Exception as e:
            log_error(f"SSH connection or deployment to {server} failed: {e}")
            overall_success = False

        # Final cleanup of the local PFX file after each deployment attempt
        if os.path.exists(temp_pfx_file):
            os.remove(temp_pfx_file)
            log_info(f"Cleaned up temporary local PFX file: {temp_pfx_file}.")

    return overall_success

# --- CORE LOGIC: PANORAMA DEPLOYMENT ---

def deploy_to_panorama(cert_name, fullchain_path, privkey_path, target_tpl, target_dg):
    """Handles the entire Panorama sequence: P12 creation, upload, commit, and push."""

    if not cert_name:
        log_info("No Panorama mapping found. Skipping Panorama deployment.")
        return True # Considered a success if no action was needed

    log_info(f"\n--- Starting Panorama Deployment for '{cert_name}' ---")
    TEMP_PFX_FILE = f"/tmp/{cert_name}.p12"

    # 1. CREATE P12 FILE
    if not create_pkcs12_pfx(fullchain_path, privkey_path, TEMP_PFX_FILE, cert_name, PASSPHRASE, is_legacy=False):
        return False # P12 creation failed

    # 2. UPLOAD CERTIFICATE
    log_info(f"2. Uploading certificate to Panorama ({cert_name})...")
    import_data = {
        'type': 'import',
        'category': 'keypair',
        'certificate-name': cert_name,
        'format': 'pkcs12',
        'passphrase': PASSPHRASE,
        'target-tpl': target_tpl,
        'key': API_KEY
    }
    IMPORT_URL = f"https://{PANORAMA_IP}/api/"
    files = {'file': (os.path.basename(TEMP_PFX_FILE), open(TEMP_PFX_FILE, 'rb'), 'application/x-pkcs12')}
    root, response_text = api_call(IMPORT_URL, method='POST', data=import_data, files=files)
    os.remove(TEMP_PFX_FILE) # Cleanup local file

    if root is None:
        log_error("Certificate import failed. Aborting Panorama deployment.")
        return False

    log_info("Certificate imported successfully.")
    # --- Check for Panorama Only Deployment ---
    IS_PANORAMA = (target_dg == "" and target_tpl == "")
    
    # 3. COMMIT CHANGES
    log_info("3. Committing changes on Panorama...")
    COMMIT_CMD = "<commit><partial><admin><member>certbot</member></admin></partial></commit>"

    commit_params = {
        'type': 'commit',
        'action': 'partial',
        'cmd': COMMIT_CMD,
        'key': API_KEY
    }
    root, response_text = api_call(IMPORT_URL, params=commit_params)
    log_info(f"Commit raw response: {response_text}")

    if root is None:
        if handle_commit_lock(response_text):
            return False
        log_error("Initial commit failed after certificate upload.")
        return False

    job_tag = root.find('.//job')
    if job_tag is None:
        log_info("Commit response contained no job ID. Treating as synchronous success.")
    else:
        JOB_ID = job_tag.text
        log_info(f"Commit job ID: {JOB_ID}. Waiting for completion...")
        if not wait_for_job(JOB_ID):
            log_error("Commit failed.")
            return False
        log_info("Commit completed successfully.")

    # 4. PUSH CONFIGURATION
    if IS_PANORAMA:
        log_info("4. Skipping 'Push' phase: Certificate deployed to Panorama Shared/Management.")
        log_info("--- Panorama Shared Deployment Complete ---")
        return True
    log_info(f"4. Pushing configuration to Template ({target_tpl}) and Device Group ({target_dg})...")
    PUSH_CMD = (
        f"<commit-all>"
        f"<shared-policy>"
        f"<device-group><entry name='{target_dg}'/></device-group>"
        f"</shared-policy>"
        f"</commit-all>"
    )
    push_params = {
        'type': 'commit',
        'action': 'all',
        'cmd': PUSH_CMD,
        'key': API_KEY
    }
    root, response_text = api_call(IMPORT_URL, params=push_params)
    log_info(f"Push raw response: {response_text}")

    if root is None:
        if handle_commit_lock(response_text):
            return False
        log_error(f"Push to Device Group failed for {target_dg}.")
        return False

    push_job_tag = root.find('.//job')
    if push_job_tag is None:
        log_info("Push response contained no job ID. Treating as synchronous success.")
    else:
        PUSH_JOB_ID = push_job_tag.text
        log_info(f"Push job ID: {PUSH_JOB_ID} enqueued successfully. Not waiting for completion.")
        log_info("*** REMINDER: Log into Panorama and verify the certificate has been successfully pushed to device group 'TGA-HOME-template' on the PA-220. ***")

    log_info("--- Panorama Deployment Complete ---")
    return True

# --- MAIN EXECUTION ORCHESTRATOR ---

def main():
    """Main orchestrator function."""
    global PANORAMA_IP
    log_info("--- Certbot Deployment Hook Started ---")

    # 1. Initial Certbot Environment Check
    CERT_DIR = os.environ.get('RENEWED_LINEAGE')
    if not CERT_DIR:
        log_error("RENEWED_LINEAGE environment variable not set. Aborting.")
        return 1

    CERTBOT_LINEAGE_NAME = os.path.basename(CERT_DIR.rstrip('/'))
    FULLCHAIN_PATH = os.path.join(CERT_DIR, "fullchain.pem")
    PRIVKEY_PATH = os.path.join(CERT_DIR, "privkey.pem")

    # 2. Load Configuration and Mappings
    try:
        # Load Panorama Config
        with open(PANORAMA_MAP_FILE, 'r') as f:
            panorama_cert_map = json.load(f)
            PANORAMA_IP = panorama_cert_map['PANORAMA_IP']

            # Extract the deployment configuration specific to the renewed certificate
            cert_deployment = panorama_cert_map['CERT_DEPLOYMENTS'].get(CERTBOT_LINEAGE_NAME)

            # If no mapping, set variables to None to skip deployment gracefully
            if cert_deployment:
                PAN_CERT_NAME = cert_deployment['panorama_name']
                TARGET_TPL_FOR_CERT = cert_deployment['target_tpl']
                TARGET_DG_FOR_CERT = cert_deployment['target_dg']
            else:
                log_info(f"No entry found in CERT_DEPLOYMENTS for {CERTBOT_LINEAGE_NAME}. Skipping Panorama deployment.")
                PAN_CERT_NAME = None # This triggers the graceful skip
                TARGET_TPL_FOR_CERT = None
                TARGET_DG_FOR_CERT = None

    except FileNotFoundError as e:
        log_error(f"Configuration file not found: {e.filename}. Aborting.")
        return 1
    except (json.JSONDecodeError, KeyError) as e:
        log_error(f"Invalid configuration file format: {e}. Aborting.")
        return 1

    # 3. PANORAMA DEPLOYMENT
    panorama_success = deploy_to_panorama(PAN_CERT_NAME, FULLCHAIN_PATH, PRIVKEY_PATH, TARGET_TPL_FOR_CERT, TARGET_DG_FOR_CERT)

    # 4. IIS DEPLOYMENT
    log_info("\nChecking for IIS deployment...")
    iis_success = deploy_to_iis_ssh(CERTBOT_LINEAGE_NAME, FULLCHAIN_PATH, PRIVKEY_PATH, IIS_MAP_FILE, PASSPHRASE)

    # 5. Determine Final Status
    if panorama_success and iis_success:
        log_info("\n--- Certbot Deployment Hook Finished: SUCCESS ---")
        return 0
    else:
        log_error("\n--- Certbot Deployment Hook Finished: FAILURE ---")
        return 1


if __name__ == "__main__":
    exit_code = 1 # Assume failure by default
    try:
        exit_code = main()
    except Exception as e:
        log_error(f"An unhandled exception occurred: {e}")
    finally:
        final_status = "SUCCESS" if exit_code == 0 else "FAILURE"
        send_final_email(final_status, log_messages)

    sys.exit(exit_code)

